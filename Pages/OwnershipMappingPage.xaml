<Page x:Class="Project.Pages.OwnershipMappingPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BackgroundColor}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">

        <Grid Margin="32">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>


            <!-- PAGE HEADER -->

            <StackPanel Grid.Row="0" Margin="0,0,0,28">

                <TextBlock Text="Ownership Mapping"
                           Style="{StaticResource PageHeaderStyle}"/>

                <TextBlock Text="Link plots with buyers or sellers and manage ownership records"
                           FontSize="15"
                           Foreground="{StaticResource TextSecondaryColor}"/>

            </StackPanel>


            <!-- INPUT FORM -->

            <Border Grid.Row="1"
                    Style="{StaticResource CardStyle}"
                    Margin="0,0,0,24">

                <Grid Margin="24">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>


                    <TextBlock Grid.Row="0"
                               Grid.ColumnSpan="3"
                               Text="Add / Edit Ownership Mapping"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,0,0,18"/>


                    <!-- Plot -->

                    <StackPanel Grid.Row="1" Grid.Column="0">

                        <TextBlock Text="Plot"
                                   Margin="0,0,0,6"/>

                        <ComboBox x:Name="cmbPlot"
                                  Style="{StaticResource ModernComboBoxStyle}"
                                  Height="38">

                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding PlotNo}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>

                        </ComboBox>

                    </StackPanel>


                    <!-- Buyer / Seller -->

                    <StackPanel Grid.Row="1" Grid.Column="2">

                        <TextBlock Text="Buyer / Seller"
                                   Margin="0,0,0,6"/>

                        <ComboBox x:Name="cmbBuyerSeller"
                                  Style="{StaticResource ModernComboBoxStyle}"
                                  Height="38">

                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>

                        </ComboBox>

                    </StackPanel>


                    <!-- Ownership Type -->

                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,16,0,0">

                        <TextBlock Text="Ownership Type"
                                   Margin="0,0,0,6"/>

                        <ComboBox x:Name="cmbOwnershipType"
                                  Style="{StaticResource ModernComboBoxStyle}"
                                  Height="38"/>

                    </StackPanel>


                    <!-- Date -->

                    <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,16,0,0">

                        <TextBlock Text="Transaction Date"
                                   Margin="0,0,0,6"/>

                        <DatePicker x:Name="dpDate"
                                    Height="38"/>

                    </StackPanel>


                    <!-- Amount -->

                    <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,16,0,0">

                        <TextBlock Text="Amount"
                                   Margin="0,0,0,6"/>

                        <TextBox x:Name="txtAmount"
                                 Style="{StaticResource ModernTextBoxStyle}"
                                 Height="38"/>

                    </StackPanel>


                    <!-- Notes -->

                    <StackPanel Grid.Row="3"
                                Grid.Column="2"
                                Margin="0,16,0,0">

                        <TextBlock Text="Notes"
                                   Margin="0,0,0,6"/>

                        <TextBox x:Name="txtNotes"
                                 Style="{StaticResource ModernTextBoxStyle}"
                                 Height="60"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"/>

                    </StackPanel>


                    <!-- BUTTONS -->

                    <StackPanel Grid.Row="4"
                                Grid.ColumnSpan="3"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,20,0,0">

                        <Button Content="Save"
                                x:Name="btnSave"
                                Style="{StaticResource SuccessButtonStyle}"
                                Width="110"
                                Height="38"
                                Margin="0,0,10,0"
                                Click="BtnSave_Click"/>

                        <Button Content="Clear"
                                x:Name="btnClear"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Width="110"
                                Height="38"
                                Margin="0,0,10,0"
                                Click="BtnClear_Click"/>

                        <Button Content="Delete"
                                x:Name="btnDelete"
                                Style="{StaticResource DangerButtonStyle}"
                                Width="110"
                                Height="38"
                                Click="BtnDelete_Click"/>

                    </StackPanel>

                </Grid>

            </Border>


            <!-- DATA GRID -->

            <Border Grid.Row="2"
                    Style="{StaticResource CardStyle}">

                <Grid Margin="24">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>


                    <TextBlock Text="Ownership Records"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,0,0,16"/>


                    <DataGrid x:Name="dgOwnership"
                              Grid.Row="1"
                              Style="{StaticResource ModernDataGridStyle}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              SelectionChanged="DgOwnership_SelectionChanged">

                        <DataGrid.Columns>

                            <DataGridTextColumn Header="Plot"
                                                Binding="{Binding PlotNo}"
                                                Width="120"/>

                            <DataGridTextColumn Header="Buyer / Seller"
                                                Binding="{Binding BuyerSellerName}"
                                                Width="*"/>

                            <DataGridTextColumn Header="Ownership Type"
                                                Binding="{Binding OwnershipType}"
                                                Width="150"/>

                            <DataGridTextColumn Header="Date"
                                                Binding="{Binding Date, StringFormat='{}{0:dd/MM/yyyy}'}"
                                                Width="120"/>

                            <DataGridTextColumn Header="Amount"
                                                Binding="{Binding Amount, StringFormat='PKR {0:N2}'}"
                                                Width="150"/>

                            <DataGridTextColumn Header="Notes"
                                                Binding="{Binding Notes}"
                                                Width="*"/>

                        </DataGrid.Columns>

                    </DataGrid>

                </Grid>

            </Border>

        </Grid>

    </ScrollViewer>

</Page>