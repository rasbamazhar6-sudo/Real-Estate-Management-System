<Page x:Class="Project.Pages.CustomerStatementsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BackgroundColor}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">

        <Grid Margin="32">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>


            <!-- PAGE HEADER -->

            <StackPanel Grid.Row="0" Margin="0,0,0,28">

                <TextBlock Text="Customer Statements"
                           Style="{StaticResource PageHeaderStyle}"/>

                <TextBlock Text="Generate and review detailed customer account statements with transaction history"
                           FontSize="15"
                           Foreground="{StaticResource TextSecondaryColor}"/>

            </StackPanel>


            <!-- PARAMETERS CARD -->

            <Border Grid.Row="1"
                    Style="{StaticResource CardStyle}"
                    Margin="0,0,0,24">

                <Grid Margin="24">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>


                    <TextBlock Grid.Row="0"
                               Grid.ColumnSpan="3"
                               Text="Statement Parameters"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,0,0,18"/>


                    <!-- CUSTOMER -->

                    <StackPanel Grid.Row="1" Grid.Column="0">

                        <TextBlock Text="Customer"
                                   Margin="0,0,0,6"/>

                        <ComboBox x:Name="cmbCustomer"
                                  Style="{StaticResource ModernComboBoxStyle}"
                                  Height="38"
                                  DisplayMemberPath="Name"
                                  SelectedValuePath="CustomerId"
                                  SelectionChanged="CmbCustomer_SelectionChanged"/>

                    </StackPanel>


                    <!-- PERIOD -->

                    <StackPanel Grid.Row="1" Grid.Column="2">

                        <TextBlock Text="Statement Period"
                                   Margin="0,0,0,6"/>

                        <ComboBox x:Name="cmbPeriod"
                                  Style="{StaticResource ModernComboBoxStyle}"
                                  Height="38"
                                  SelectionChanged="CmbPeriod_SelectionChanged">

                            <ComboBoxItem Content="Last 30 Days" IsSelected="True"/>
                            <ComboBoxItem Content="Last 60 Days"/>
                            <ComboBoxItem Content="Last 90 Days"/>
                            <ComboBoxItem Content="Custom Range"/>

                        </ComboBox>

                    </StackPanel>


                    <!-- DATE RANGE -->

                    <StackPanel Grid.Row="2"
                                Grid.Column="0"
                                x:Name="pnlDateRange"
                                Visibility="Collapsed"
                                Margin="0,16,0,0">

                        <TextBlock Text="From Date" Margin="0,0,0,6"/>

                        <DatePicker x:Name="dpFromDate"
                                    Height="38"/>

                    </StackPanel>


                    <StackPanel Grid.Row="2"
                                Grid.Column="2"
                                x:Name="pnlToDate"
                                Visibility="Collapsed"
                                Margin="0,16,0,0">

                        <TextBlock Text="To Date" Margin="0,0,0,6"/>

                        <DatePicker x:Name="dpToDate"
                                    Height="38"/>

                    </StackPanel>


                    <!-- BUTTONS -->

                    <StackPanel Grid.Row="3"
                                Grid.ColumnSpan="3"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,20,0,0">

                        <Button x:Name="btnGenerate"
                                Content="Generate Statement"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Width="180"
                                Height="42"
                                Margin="0,0,10,0"
                                Click="BtnGenerate_Click"/>

                        <Button x:Name="btnExportPDF"
                                Content="Export PDF"
                                Style="{StaticResource ExportPdfButtonStyle}"
                                Width="130"
                                Height="42"
                                Margin="0,0,10,0"
                                IsEnabled="False"
                                Click="BtnExportPDF_Click"/>

                        <Button x:Name="btnExportExcel"
                                Content="Export Excel"
                                Style="{StaticResource ExportExcelButtonStyle}"
                                Width="130"
                                Height="42"
                                Margin="0, 0, 10, 0"
                                IsEnabled="False"
                                Click="BtnExportExcel_Click"/>

                    </StackPanel>

                </Grid>

            </Border>


            <!-- STATEMENT PREVIEW -->

            <Border Grid.Row="2"
                    Style="{StaticResource CardStyle}">

                <Grid Margin="24">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>


                    <!-- STATEMENT HEADER -->

                    <TextBlock Text="Account Statement"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Margin="0,0,0,16"/>


                    <!-- CUSTOMER DETAILS -->

                    <Grid Grid.Row="1" Margin="0,0,0,20">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>

                            <TextBlock x:Name="txtCustomerName"
                                       FontSize="16"
                                       FontWeight="SemiBold"/>

                            <TextBlock x:Name="txtCustomerAddress"
                                       Foreground="{StaticResource TextSecondaryColor}"/>

                        </StackPanel>


                        <StackPanel Grid.Column="1"
                                    HorizontalAlignment="Right">

                            <TextBlock Text="Statement Period"
                                       Foreground="{StaticResource TextSecondaryColor}"/>

                            <TextBlock x:Name="txtStatementPeriod"
                                       FontWeight="SemiBold"/>

                        </StackPanel>

                    </Grid>


                    <!-- SUMMARY -->

                    <Border Grid.Row="1"
                            Background="#F7F9FC"
                            CornerRadius="6"
                            Padding="14"
                            Margin="0,50,0,20">

                        <Grid>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>


                            <StackPanel>

                                <TextBlock Text="Opening Balance"
                                           FontSize="12"
                                           Foreground="{StaticResource TextSecondaryColor}"/>

                                <TextBlock x:Name="txtOpeningBalance"
                                           FontSize="16"
                                           FontWeight="SemiBold"/>

                            </StackPanel>


                            <StackPanel Grid.Column="1">

                                <TextBlock Text="Closing Balance"
                                           FontSize="12"
                                           Foreground="{StaticResource TextSecondaryColor}"/>

                                <TextBlock x:Name="txtClosingBalance"
                                           FontSize="16"
                                           FontWeight="SemiBold"/>

                            </StackPanel>


                            <StackPanel Grid.Column="2">

                                <TextBlock Text="Outstanding"
                                           FontSize="12"
                                           Foreground="{StaticResource TextSecondaryColor}"/>

                                <TextBlock x:Name="txtOutstanding"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource ErrorColor}"/>

                            </StackPanel>

                        </Grid>

                    </Border>


                    <!-- TRANSACTIONS -->

                    <DataGrid Grid.Row="2"
                              x:Name="dgStatement"
                              Style="{StaticResource ModernDataGridStyle}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column">

                        <DataGrid.Columns>

                            <DataGridTextColumn Header="Date"
                                                Binding="{Binding TransactionDate, StringFormat='{}{0:dd/MM/yyyy}'}"
                                                Width="120"/>

                            <DataGridTextColumn Header="Description"
                                                Binding="{Binding Description}"
                                                Width="*"/>

                            <DataGridTextColumn Header="Reference"
                                                Binding="{Binding Reference}"
                                                Width="150"/>

                            <DataGridTextColumn Header="Debit"
                                                Binding="{Binding Debit, StringFormat='PKR {0:N2}'}"
                                                Width="120"/>

                            <DataGridTextColumn Header="Credit"
                                                Binding="{Binding Credit, StringFormat='PKR {0:N2}'}"
                                                Width="120"/>

                            <DataGridTextColumn Header="Balance"
                                                Binding="{Binding Balance, StringFormat='PKR {0:N2}'}"
                                                Width="140"/>

                        </DataGrid.Columns>

                    </DataGrid>

                </Grid>

            </Border>

        </Grid>

    </ScrollViewer>

</Page>