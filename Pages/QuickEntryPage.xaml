<Page x:Class="Project.Pages.QuickEntryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BackgroundColor}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">

        <Grid Margin="32">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>


            <!-- PAGE HEADER -->

            <StackPanel Grid.Row="0" Margin="0,0,0,28">

                <TextBlock Text="Quick Entry"
                           FontSize="32"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryColor}"
                           Margin="0,0,0,8"/>

                <TextBlock Text="Quickly record debit and credit transactions for customers"
                           FontSize="15"
                           Foreground="{StaticResource TextSecondaryColor}"/>

            </StackPanel>


            <!-- TRANSACTION FORM -->

            <Border Grid.Row="1"
                    Style="{StaticResource CardStyle}"
                    Margin="0,0,0,24">

                <Grid Margin="24">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>


                    <!-- FORM TITLE -->

                    <TextBlock Grid.Row="0"
                               Grid.ColumnSpan="3"
                               Text="Transaction Details"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,0,0,18"/>


                    <!-- CUSTOMER -->

                    <StackPanel Grid.Row="1"
                                Grid.ColumnSpan="3">

                        <TextBlock Text="Customer"
                                   Margin="0,0,0,6"/>

                        <ComboBox x:Name="cmbCustomer"
                                  Style="{StaticResource ModernComboBoxStyle}"
                                  Height="40"
                                  DisplayMemberPath="Name"
                                  SelectedValuePath="CustomerId"/>

                    </StackPanel>


                    <!-- TRANSACTION TYPE -->

                    <StackPanel Grid.Row="2"
                                Grid.Column="0"
                                Margin="0,16,0,0">

                        <TextBlock Text="Transaction Type"
                                   Margin="0,0,0,6"/>

                        <ComboBox x:Name="cmbTransactionType"
                                  Style="{StaticResource ModernComboBoxStyle}"
                                  Height="40"
                                  SelectionChanged="CmbTransactionType_SelectionChanged">

                            <ComboBoxItem Content="Debit" IsSelected="True"/>
                            <ComboBoxItem Content="Credit"/>

                        </ComboBox>

                    </StackPanel>


                    <!-- AMOUNT -->

                    <StackPanel Grid.Row="2"
                                Grid.Column="2"
                                Margin="0,16,0,0">

                        <TextBlock Text="Amount"
                                   Margin="0,0,0,6"/>

                        <TextBox x:Name="txtAmount"
                                 Style="{StaticResource ModernTextBoxStyle}"
                                 Height="40"/>

                    </StackPanel>


                    <!-- DATE -->

                    <StackPanel Grid.Row="3"
                                Grid.Column="0"
                                Margin="0,16,0,0">

                        <TextBlock Text="Transaction Date"
                                   Margin="0,0,0,6"/>

                        <DatePicker x:Name="dpTransactionDate"
                                    Height="40"
                                    SelectedDateChanged="DpTransactionDate_SelectionChanged"/>

                    </StackPanel>


                    <!-- REFERENCE -->

                    <StackPanel Grid.Row="3"
                                Grid.Column="2"
                                Margin="0,16,0,0">

                        <TextBlock Text="Reference Number"
                                   Margin="0,0,0,6"/>

                        <TextBox x:Name="txtReference"
                                 Style="{StaticResource ModernTextBoxStyle}"
                                 Height="40"/>

                    </StackPanel>


                    <!-- DESCRIPTION -->

                    <StackPanel Grid.Row="4"
                                Grid.ColumnSpan="3"
                                Margin="0,16,0,0">

                        <TextBlock Text="Description"
                                   Margin="0,0,0,6"/>

                        <TextBox x:Name="txtDescription"
                                 Style="{StaticResource ModernTextBoxStyle}"
                                 Height="80"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"/>

                    </StackPanel>


                    <!-- ACTION BUTTONS -->

                    <StackPanel Grid.Row="5"
                                Grid.ColumnSpan="3"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,24,0,0">

                        <Button x:Name="btnSave"
                                Content="Save Transaction"
                                Style="{StaticResource SuccessButtonStyle}"
                                Width="160"
                                Height="42"
                                Margin="0,0,12,0"
                                Click="BtnSave_Click"/>

                        <Button x:Name="btnClear"
                                Content="Clear"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Width="120"
                                Height="42"
                                Click="BtnClear_Click"/>

                    </StackPanel>

                </Grid>

            </Border>


            <!-- RECENT TRANSACTIONS -->

            <Border Grid.Row="2"
                    Style="{StaticResource CardStyle}">

                <Grid Margin="24">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>


                    <TextBlock Text="Recent Transactions"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,0,0,16"/>


                    <DataGrid x:Name="dgTransactions"
                              Grid.Row="1"
                              Style="{StaticResource ModernDataGridStyle}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              HeadersVisibility="Column"
                              SelectionChanged="DgTransactions_SelectionChanged">

                        <DataGrid.Columns>

                            <DataGridTextColumn Header="Date"
                                Binding="{Binding TransactionDate, StringFormat='{}{0:dd/MM/yyyy}'}"
                                Width="120"/>

                            <DataGridTextColumn Header="Customer"
                                Binding="{Binding CustomerName}"
                                Width="*"/>

                            <DataGridTextColumn Header="Type"
                                Binding="{Binding TransactionType}"
                                Width="110"/>

                            <DataGridTextColumn Header="Amount"
                                Binding="{Binding Amount, StringFormat='PKR {0:N2}'}"
                                Width="130"/>

                            <DataGridTextColumn Header="Reference"
                                Binding="{Binding Reference}"
                                Width="150"/>

                            <DataGridTextColumn Header="Description"
                                Binding="{Binding Description}"
                                Width="*"/>

                        </DataGrid.Columns>

                    </DataGrid>

                </Grid>

            </Border>

        </Grid>

    </ScrollViewer>

</Page>