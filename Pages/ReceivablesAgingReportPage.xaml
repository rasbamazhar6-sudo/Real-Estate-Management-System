<Page x:Class="Project.Pages.ReceivablesAgingReportPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BackgroundColor}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">

        <Grid Margin="32">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>


            <!-- PAGE HEADER -->

            <StackPanel Grid.Row="0" Margin="0,0,0,28">

                <TextBlock Text="Receivables Aging Report"
                           FontSize="32"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryColor}"
                           Margin="0,0,0,8"/>

                <TextBlock Text="View aging breakdown of outstanding receivables by customer"
                           FontSize="15"
                           Foreground="{StaticResource TextSecondaryColor}"/>

            </StackPanel>


            <!-- FILTER CARD -->

            <Border Grid.Row="1"
                    Style="{StaticResource CardStyle}"
                    Margin="0,0,0,24">

                <Grid Margin="24">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>


                    <!-- SECTION TITLE -->

                    <TextBlock Grid.Row="0"
                               Grid.ColumnSpan="5"
                               Text="Report Filters"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,0,0,16"/>


                    <!-- AS OF DATE -->

                    <StackPanel Grid.Row="1" Grid.Column="0">
                        <TextBlock Text="As of Date"
                                   Margin="0,0,0,6"/>
                        <DatePicker x:Name="dpAsOfDate"
                                    Height="40"
                                    SelectedDateChanged="DpAsOfDate_SelectionChanged"/>
                    </StackPanel>


                    <!-- CUSTOMER FILTER -->

                    <StackPanel Grid.Row="1" Grid.Column="2">
                        <TextBlock Text="Customer (Optional)"
                                   Margin="0,0,0,6"/>

                        <ComboBox x:Name="cmbCustomer"
                                  Style="{StaticResource ModernComboBoxStyle}"
                                  Height="40"
                                  DisplayMemberPath="Name"
                                  SelectedValuePath="PartyId"
                                  SelectionChanged="CmbCustomer_SelectionChanged"/>
                    </StackPanel>


                    <!-- ACTION BUTTONS -->

                    <StackPanel Grid.Row="1"
                                Grid.Column="4"
                                Orientation="Horizontal"
                                VerticalAlignment="Bottom">

                        <Button x:Name="btnGenerate"
                                Content="Generate Report"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Width="150"
                                Height="42"
                                Margin="0,0,10,0"
                                Click="BtnGenerate_Click"/>

                        <Button x:Name="btnExportPDF"
                                Content="Export PDF"
                                Style="{StaticResource ExportPdfButtonStyle}"
                                Width="130"
                                Height="42"
                                Margin="0,0,10,0"
                                Click="BtnExportPDF_Click"/>

                        <Button x:Name="btnExportExcel"
                                Content="Export Excel"
                                Style="{StaticResource ExportExcelButtonStyle}"
                                Width="130"
                                Height="42"
                                Click="BtnExportExcel_Click"/>

                    </StackPanel>

                </Grid>

            </Border>


            <!-- REPORT SECTION -->

            <Border Grid.Row="2"
                    Style="{StaticResource CardStyle}">

                <Grid Margin="24">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>


                    <!-- TITLE -->

                    <TextBlock Text="Aging Summary"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,0,0,16"/>


                    <!-- SUMMARY CARDS -->

                    <UniformGrid Grid.Row="1"
                                 Columns="4"
                                 Margin="0,0,0,24">

                        <!-- CURRENT -->

                        <Border Background="#E3F2FD"
                                CornerRadius="8"
                                Padding="18"
                                Margin="0,0,16,0">

                            <StackPanel>
                                <TextBlock Text="Current (0-30 days)"
                                           FontSize="12"
                                           Foreground="{StaticResource TextSecondaryColor}"
                                           Margin="0,0,0,4"/>

                                <TextBlock x:Name="txtCurrent"
                                           Text="PKR 0.00"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource PrimaryColor}"/>
                            </StackPanel>

                        </Border>


                        <!-- 31-60 -->

                        <Border Background="#FFF3E0"
                                CornerRadius="8"
                                Padding="18"
                                Margin="0,0,16,0">

                            <StackPanel>
                                <TextBlock Text="31-60 Days"
                                           FontSize="12"
                                           Foreground="{StaticResource TextSecondaryColor}"
                                           Margin="0,0,0,4"/>

                                <TextBlock x:Name="txtDays31to60"
                                           Text="PKR 0.00"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           Foreground="#FF9800"/>
                            </StackPanel>

                        </Border>


                        <!-- 61-90 -->

                        <Border Background="#FFEBEE"
                                CornerRadius="8"
                                Padding="18"
                                Margin="0,0,16,0">

                            <StackPanel>
                                <TextBlock Text="61-90 Days"
                                           FontSize="12"
                                           Foreground="{StaticResource TextSecondaryColor}"
                                           Margin="0,0,0,4"/>

                                <TextBlock x:Name="txtDays61to90"
                                           Text="PKR 0.00"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           Foreground="#F44336"/>
                            </StackPanel>

                        </Border>


                        <!-- OVER 90 -->

                        <Border Background="#F3E5F5"
                                CornerRadius="8"
                                Padding="18">

                            <StackPanel>
                                <TextBlock Text="Over 90 Days"
                                           FontSize="12"
                                           Foreground="{StaticResource TextSecondaryColor}"
                                           Margin="0,0,0,4"/>

                                <TextBlock x:Name="txtOver90"
                                           Text="PKR 0.00"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           Foreground="#9C27B0"/>
                            </StackPanel>

                        </Border>

                    </UniformGrid>


                    <!-- REPORT GRID -->

                    <DataGrid x:Name="dgAgingReport"
                              Grid.Row="2"
                              Style="{StaticResource ModernDataGridStyle}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single">

                        <DataGrid.Columns>

                            <DataGridTextColumn Header="Customer"
                                Binding="{Binding CustomerName}"
                                Width="*"/>

                            <DataGridTextColumn Header="Total Outstanding"
                                Binding="{Binding TotalOutstanding, StringFormat='PKR {0:N2}'}"
                                Width="160"/>

                            <DataGridTextColumn Header="0-30 Days"
                                Binding="{Binding Current, StringFormat='PKR {0:N2}'}"
                                Width="120"/>

                            <DataGridTextColumn Header="31-60 Days"
                                Binding="{Binding Days31to60, StringFormat='PKR {0:N2}'}"
                                Width="120"/>

                            <DataGridTextColumn Header="61-90 Days"
                                Binding="{Binding Days61to90, StringFormat='PKR {0:N2}'}"
                                Width="120"/>

                            <DataGridTextColumn Header="Over 90 Days"
                                Binding="{Binding Over90, StringFormat='PKR {0:N2}'}"
                                Width="120"/>

                            <DataGridTextColumn Header="Oldest Invoice"
                                Binding="{Binding OldestInvoiceDate, StringFormat='{}{0:dd/MM/yyyy}'}"
                                Width="150"/>

                        </DataGrid.Columns>

                    </DataGrid>

                </Grid>

            </Border>

        </Grid>

    </ScrollViewer>

</Page>