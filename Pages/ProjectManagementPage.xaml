<Page x:Class="Project.Pages.ProjectManagementPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BackgroundColor}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">

        <Grid Margin="32">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>


            <!-- PAGE HEADER -->

            <StackPanel Grid.Row="0" Margin="0,0,0,28">

                <TextBlock Text="Project Management"
                           FontSize="32"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryColor}"
                           Margin="0,0,0,8"/>

                <TextBlock Text="Create and manage real estate projects"
                           FontSize="15"
                           Foreground="{StaticResource TextSecondaryColor}"/>

            </StackPanel>


            <!-- PROJECT FORM -->

            <Border Grid.Row="1"
                    Style="{StaticResource CardStyle}"
                    Margin="0,0,0,24">

                <Grid Margin="24">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>


                    <!-- FORM TITLE -->

                    <TextBlock Grid.Row="0"
                               Grid.ColumnSpan="3"
                               Text="Add / Edit Project"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,0,0,18"/>


                    <!-- PROJECT ID -->

                    <StackPanel Grid.Row="1" Grid.Column="0">
                        <TextBlock Text="Project ID" Margin="0,0,0,6"/>
                        <TextBox x:Name="txtProjectId"
                                 Style="{StaticResource ModernTextBoxStyle}"
                                 Height="40"
                                 IsReadOnly="True"/>
                    </StackPanel>


                    <!-- PROJECT NAME -->

                    <StackPanel Grid.Row="1" Grid.Column="2">
                        <TextBlock Text="Project Name" Margin="0,0,0,6"/>
                        <TextBox x:Name="txtProjectName"
                                 Style="{StaticResource ModernTextBoxStyle}"
                                 Height="40"/>
                    </StackPanel>


                    <!-- LOCATION -->

                    <StackPanel Grid.Row="2"
                                Grid.Column="0"
                                Grid.ColumnSpan="3"
                                Margin="0,16,0,0">

                        <TextBlock Text="Location" Margin="0,0,0,6"/>

                        <TextBox x:Name="txtLocation"
                                 Style="{StaticResource ModernTextBoxStyle}"
                                 Height="40"/>

                    </StackPanel>


                    <!-- STATUS -->

                    <StackPanel Grid.Row="3"
                                Grid.Column="0"
                                Margin="0,16,0,0">

                        <TextBlock Text="Status" Margin="0,0,0,6"/>

                        <ComboBox x:Name="cmbStatus"
                                  Style="{StaticResource ModernComboBoxStyle}"
                                  Height="40"/>

                    </StackPanel>


                    <!-- ACTION BUTTONS -->

                    <StackPanel Grid.Row="4"
                                Grid.ColumnSpan="3"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,24,0,0">

                        <Button Content="Save"
                                x:Name="btnSave"
                                Style="{StaticResource SuccessButtonStyle}"
                                Width="130"
                                Height="42"
                                Margin="0,0,12,0"
                                Click="BtnSave_Click"/>

                        <Button Content="Clear"
                                x:Name="btnClear"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Width="120"
                                Height="42"
                                Margin="0,0,12,0"
                                Click="BtnClear_Click"/>

                        <Button Content="Delete"
                                x:Name="btnDelete"
                                Style="{StaticResource DangerButtonStyle}"
                                Width="120"
                                Height="42"
                                Click="BtnDelete_Click"/>

                    </StackPanel>

                </Grid>

            </Border>


            <!-- PROJECT LIST -->

            <Border Grid.Row="2"
                    Style="{StaticResource CardStyle}">

                <Grid Margin="24">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>


                    <TextBlock Text="Projects List"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,0,0,16"/>


                    <DataGrid x:Name="dgProjects"
                              Grid.Row="1"
                              Style="{StaticResource ModernDataGridStyle}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              SelectionChanged="DgProjects_SelectionChanged">

                        <DataGrid.Columns>

                            <DataGridTextColumn Header="Project ID"
                                                Binding="{Binding ProjectId}"
                                                Width="120"/>

                            <DataGridTextColumn Header="Project Name"
                                                Binding="{Binding ProjectName}"
                                                Width="*"/>

                            <DataGridTextColumn Header="Location"
                                                Binding="{Binding Location}"
                                                Width="220"/>

                            <DataGridTextColumn Header="Status"
                                                Binding="{Binding Status}"
                                                Width="150"/>

                        </DataGrid.Columns>

                    </DataGrid>

                </Grid>

            </Border>

        </Grid>

    </ScrollViewer>

</Page>