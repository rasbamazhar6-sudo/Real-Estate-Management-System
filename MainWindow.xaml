<Window x:Class="Project.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Real Estate Management System"
        Height="900"
        Width="1600"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        Background="Transparent"
        Icon="/Resources/office-block.ico">

    <Window.Resources>

        <!-- Window Control Button -->

        <Style x:Key="WindowControlButtonStyle" TargetType="Button">

            <Setter Property="Width" Value="46"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="Transparent">
                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border"
                                        Property="Background"
                                        Value="#1E88E5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>

        </Style>


        <!-- Close Button -->

        <Style x:Key="WindowCloseButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource WindowControlButtonStyle}">

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E53935"/>
                </Trigger>
            </Style.Triggers>

        </Style>

    </Window.Resources>


    <!-- Resize Grid -->

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="6"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="6"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="6"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="6"/>
        </Grid.ColumnDefinitions>


        <!-- Resize Areas -->

        <Border Grid.Row="0" Grid.Column="1" Cursor="SizeNS" MouseDown="ResizeTop"/>
        <Border Grid.Row="2" Grid.Column="1" Cursor="SizeNS" MouseDown="ResizeBottom"/>
        <Border Grid.Row="1" Grid.Column="0" Cursor="SizeWE" MouseDown="ResizeLeft"/>
        <Border Grid.Row="1" Grid.Column="2" Cursor="SizeWE" MouseDown="ResizeRight"/>


        <!-- Window Content -->

        <Border Grid.Row="1"
                Grid.Column="1"
                CornerRadius="10"
                Background="{StaticResource SurfaceColor}">

            <Border.Effect>
                <DropShadowEffect BlurRadius="20"
                                  ShadowDepth="0"
                                  Opacity="0.25"/>
            </Border.Effect>

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>


                <!-- TITLE BAR -->

                <Border Grid.Row="0"
                        Background="{StaticResource HeaderGradientBrush}"
                        CornerRadius="10,10,0,0"
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">

                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>


                        <!-- Title -->

                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Margin="14,0">

                            <TextBlock Text="🏢"
                                       FontSize="16"
                                       Margin="0,0,8,0"/>

                            <TextBlock Text="Real Estate Management System"
                                       Foreground="White"
                                       FontSize="14"
                                       FontWeight="SemiBold"/>

                        </StackPanel>


                        <!-- Window Buttons -->

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal">

                            <!-- Minimize -->

                            <Button x:Name="btnMinimize"
                                    Style="{StaticResource WindowControlButtonStyle}"
                                    Click="BtnMinimize_Click">

                                <Path Stroke="White"
                                      StrokeThickness="2"
                                      Data="M 3 10 L 13 10"
                                      Width="14"
                                      Height="14"/>

                            </Button>


                            <!-- Maximize -->

                            <Button x:Name="btnMaximize"
                                    Style="{StaticResource WindowControlButtonStyle}"
                                    Click="BtnMaximize_Click">

                                <Rectangle Stroke="White"
                                           StrokeThickness="2"
                                           Width="12"
                                           Height="10"/>

                            </Button>


                            <!-- Close -->

                            <Button x:Name="btnClose"
                                    Style="{StaticResource WindowCloseButtonStyle}"
                                    Click="BtnClose_Click">

                                <Path Stroke="White"
                                      StrokeThickness="2"
                                      Data="M 3 3 L 13 13 M 13 3 L 3 13"
                                      Width="14"
                                      Height="14"/>

                            </Button>

                        </StackPanel>

                    </Grid>

                </Border>


                <!-- MAIN CONTENT -->

                <Frame x:Name="MainFrame"
                   Grid.Row="1"
                   NavigationUIVisibility="Hidden"
                   Background="{StaticResource BackgroundColor}"
                   Source="Pages/WelcomePage.xaml"
                   Navigated="MainFrame_Navigated"/>

            </Grid>

        </Border>

    </Grid>

</Window>