<Page x:Class="Project.Pages.PlotVisualDashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BackgroundColor}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">

        <Grid Margin="32">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>


            <!-- PAGE HEADER -->

            <StackPanel Grid.Row="0" Margin="0,0,0,28">

                <TextBlock Text="Plot Visual Dashboard"
                           FontSize="32"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryColor}"
                           Margin="0,0,0,8"/>

                <TextBlock Text="Visual representation of plots with availability status"
                           FontSize="15"
                           Foreground="{StaticResource TextSecondaryColor}"/>

            </StackPanel>


            <!-- FILTER CARD -->

            <Border Grid.Row="1"
                    Style="{StaticResource CardStyle}"
                    Margin="0,0,0,24">

                <Grid Margin="24">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>


                    <!-- SECTION TITLE -->

                    <TextBlock Grid.Row="0"
                               Grid.ColumnSpan="5"
                               Text="Filters"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,0,0,16"/>


                    <!-- PROJECT FILTER -->

                    <StackPanel Grid.Row="1" Grid.Column="0">
                        <TextBlock Text="Project"
                                   Margin="0,0,0,6"/>
                        <ComboBox x:Name="cmbProject"
                                  Style="{StaticResource ModernComboBoxStyle}"
                                  Height="40"
                                  SelectionChanged="CmbProject_SelectionChanged"/>
                    </StackPanel>


                    <!-- STATUS FILTER -->

                    <StackPanel Grid.Row="1" Grid.Column="2">
                        <TextBlock Text="Status Filter"
                                   Margin="0,0,0,6"/>
                        <ComboBox x:Name="cmbStatusFilter"
                                  Style="{StaticResource ModernComboBoxStyle}"
                                  Height="40"
                                  SelectionChanged="CmbStatusFilter_SelectionChanged"/>
                    </StackPanel>


                    <!-- REFRESH BUTTON -->

                    <Button Grid.Row="1"
                            Grid.Column="4"
                            Content="Refresh"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Width="120"
                            Height="42"
                            VerticalAlignment="Bottom"
                            Click="BtnRefresh_Click"/>

                </Grid>

            </Border>


            <!-- VISUAL DASHBOARD -->

            <Border Grid.Row="2"
                    Style="{StaticResource CardStyle}">

                <Grid Margin="24">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>


                    <!-- TITLE -->

                    <TextBlock Text="Plot Grid View"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,0,0,16"/>


                    <!-- STATUS LEGEND -->

                    <StackPanel Grid.Row="1"
                                Orientation="Horizontal"
                                Margin="0,0,0,20">

                        <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                            <Rectangle Width="16" Height="16" Fill="#4CAF50" Margin="0,0,6,0"/>
                            <TextBlock Text="Available"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                            <Rectangle Width="16" Height="16" Fill="#FFC107" Margin="0,0,6,0"/>
                            <TextBlock Text="Reserved"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <Rectangle Width="16" Height="16" Fill="#F44336" Margin="0,0,6,0"/>
                            <TextBlock Text="Sold"/>
                        </StackPanel>

                    </StackPanel>


                    <!-- PLOT GRID -->

                    <ScrollViewer Grid.Row="2"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto">

                        <ItemsControl x:Name="plotGrid">

                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="5"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>


                            <ItemsControl.ItemTemplate>

                                <DataTemplate>

                                    <Border BorderBrush="{StaticResource DividerColor}"
                                            BorderThickness="1"
                                            Margin="6"
                                            Padding="12"
                                            CornerRadius="6"
                                            Background="{Binding StatusColor}">

                                        <StackPanel HorizontalAlignment="Center">

                                            <TextBlock Text="{Binding PlotNo}"
                                                       FontSize="16"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,0,0,6"/>

                                            <TextBlock Text="{Binding Status}"
                                                       FontSize="12"
                                                       Foreground="{Binding TextColor}"
                                                       HorizontalAlignment="Center"/>

                                            <TextBlock Text="{Binding Size, StringFormat='{}{0} marla'}"
                                                       FontSize="11"
                                                       Foreground="{Binding TextColor}"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,4,0,0"/>

                                        </StackPanel>

                                    </Border>

                                </DataTemplate>

                            </ItemsControl.ItemTemplate>

                        </ItemsControl>

                    </ScrollViewer>

                </Grid>

            </Border>

        </Grid>

    </ScrollViewer>

</Page>