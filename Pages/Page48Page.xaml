<Page x:Class="Project.Pages.Page48Page"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BackgroundColor}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">

        <Grid Margin="32">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>


            <!-- PAGE HEADER -->

            <StackPanel Grid.Row="0" Margin="0,0,0,28">

                <TextBlock Text="Installments &amp; Payment Plans"
                           FontSize="32"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryColor}"
                           Margin="0,0,0,8"/>

                <TextBlock Text="Create and manage buyer payment plans and installment schedules"
                           FontSize="15"
                           Foreground="{StaticResource TextSecondaryColor}"/>

            </StackPanel>



            <!-- PAYMENT PLAN FORM -->

            <Border Grid.Row="1"
                    Style="{StaticResource CardStyle}"
                    Margin="0,0,0,24">

                <Grid Margin="24">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>


                    <!-- FORM TITLE -->

                    <TextBlock Grid.Row="0"
                               Grid.ColumnSpan="3"
                               Text="Payment Plan Details"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,0,0,20"/>


                    <!-- BUYER -->

                    <StackPanel Grid.Row="1" Grid.Column="0">

                        <TextBlock Text="Buyer" Margin="0,0,0,6"/>

                        <ComboBox x:Name="cmbBuyer"
                                  Style="{StaticResource ModernComboBoxStyle}"
                                  Height="40"
                                  DisplayMemberPath="Name"
                                  SelectedValuePath="BuyerId"/>

                    </StackPanel>


                    <!-- PLOT -->

                    <StackPanel Grid.Row="1" Grid.Column="2">

                        <TextBlock Text="Plot" Margin="0,0,0,6"/>

                        <ComboBox x:Name="cmbPlot"
                                  Style="{StaticResource ModernComboBoxStyle}"
                                  Height="40"
                                  DisplayMemberPath="PlotNo"
                                  SelectedValuePath="PlotId"/>

                    </StackPanel>


                    <!-- PLAN TYPE -->

                    <StackPanel Grid.Row="2"
                                Grid.Column="0"
                                Margin="0,16,0,0">

                        <TextBlock Text="Plan Type" Margin="0,0,0,6"/>

                        <ComboBox x:Name="cmbPlanType"
                                  Style="{StaticResource ModernComboBoxStyle}"
                                  Height="40"
                                  SelectionChanged="CmbPlanType_SelectionChanged">

                            <ComboBoxItem Content="Monthly" IsSelected="True"/>
                            <ComboBoxItem Content="Quarterly"/>
                            <ComboBoxItem Content="Bi-annual"/>
                            <ComboBoxItem Content="Custom"/>

                        </ComboBox>

                    </StackPanel>


                    <!-- TOTAL AMOUNT -->

                    <StackPanel Grid.Row="2"
                                Grid.Column="2"
                                Margin="0,16,0,0">

                        <TextBlock Text="Total Amount" Margin="0,0,0,6"/>

                        <TextBox x:Name="txtTotalAmount"
                                 Style="{StaticResource ModernTextBoxStyle}"
                                 Height="40"
                                 TextChanged="TxtTotalAmount_TextChanged"/>

                    </StackPanel>


                    <!-- DOWN PAYMENT -->

                    <StackPanel Grid.Row="3"
                                Grid.Column="0"
                                Margin="0,16,0,0">

                        <TextBlock Text="Down Payment" Margin="0,0,0,6"/>

                        <TextBox x:Name="txtDownPayment"
                                 Style="{StaticResource ModernTextBoxStyle}"
                                 Height="40"
                                 TextChanged="TxtDownPayment_TextChanged"/>

                    </StackPanel>


                    <!-- INSTALLMENTS -->

                    <StackPanel Grid.Row="3"
                                Grid.Column="2"
                                Margin="0,16,0,0">

                        <TextBlock Text="Number of Installments" Margin="0,0,0,6"/>

                        <TextBox x:Name="txtInstallments"
                                 Style="{StaticResource ModernTextBoxStyle}"
                                 Height="40"
                                 TextChanged="TxtInstallments_TextChanged"/>

                    </StackPanel>


                    <!-- INSTALLMENT AMOUNT -->

                    <StackPanel Grid.Row="4"
                                Grid.Column="0"
                                Margin="0,16,0,0">

                        <TextBlock Text="Installment Amount" Margin="0,0,0,6"/>

                        <TextBox x:Name="txtInstallmentAmount"
                                 Style="{StaticResource ModernTextBoxStyle}"
                                 Height="40"
                                 IsReadOnly="True"
                                 Background="#F5F5F5"/>

                    </StackPanel>


                    <!-- START DATE -->

                    <StackPanel Grid.Row="4"
                                Grid.Column="2"
                                Margin="0,16,0,0">

                        <TextBlock Text="Start Date" Margin="0,0,0,6"/>

                        <DatePicker x:Name="dpStartDate"
                                    Height="40"/>

                    </StackPanel>


                    <!-- STATUS -->

                    <StackPanel Grid.Row="5"
                                Grid.Column="0"
                                Margin="0,16,0,0">

                        <TextBlock Text="Status" Margin="0,0,0,6"/>

                        <ComboBox x:Name="cmbStatus"
                                  Style="{StaticResource ModernComboBoxStyle}"
                                  Height="40">

                            <ComboBoxItem Content="Active" IsSelected="True"/>
                            <ComboBoxItem Content="Completed"/>
                            <ComboBoxItem Content="Cancelled"/>
                            <ComboBoxItem Content="On Hold"/>

                        </ComboBox>

                    </StackPanel>



                    <!-- REMINDERS -->

                    <StackPanel Grid.Row="6"
                                Grid.ColumnSpan="3"
                                Margin="0,24,0,0">

                        <TextBlock Text="Auto Reminders"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,12"/>

                        <StackPanel Orientation="Horizontal">

                            <CheckBox x:Name="chkOverdueReminder"
                                      Content="Send overdue reminders"
                                      Margin="0,0,30,0"
                                      IsChecked="True"/>

                            <CheckBox x:Name="chkUpcomingReminder"
                                      Content="Send reminder before due date"
                                      IsChecked="True"/>

                        </StackPanel>

                    </StackPanel>


                    <!-- ACTION BUTTONS -->

                    <StackPanel Grid.Row="7"
                                Grid.ColumnSpan="3"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,24,0,0">

                        <Button x:Name="btnSave"
                                Content="Save Plan"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Width="150"
                                Height="42"
                                Margin="0,0,12,0"
                                Click="BtnSave_Click"/>

                        <Button x:Name="btnClear"
                                Content="Clear"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Width="120"
                                Height="42"
                                Margin="0,0,12,0"
                                Click="BtnClear_Click"/>

                        <Button x:Name="btnDelete"
                                Content="Delete"
                                Style="{StaticResource DangerButtonStyle}"
                                Width="120"
                                Height="42"
                                Click="BtnDelete_Click"/>

                    </StackPanel>

                </Grid>

            </Border>



            <!-- SEARCH / FILTER -->

            <Border Grid.Row="2"
                    Style="{StaticResource CardStyle}"
                    Margin="0,0,0,24">

                <Grid Margin="24">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">

                        <TextBlock Text="Payment Plan Search" Margin="0,0,0,6"/>
                        <TextBox x:Name="txtSearch"
                             Style="{StaticResource ModernTextBoxStyle}"
                             Height="40"
                             TextChanged="TxtSearch_TextChanged"
                             Tag="Search buyer, plot or plan ID"/>
                        
                    </StackPanel>

                    <StackPanel Grid.Column="2">

                        <TextBlock Text="Filter Type" Margin="0,0,0,6"/>
                        <ComboBox x:Name="cmbFilterStatus"
                              Style="{StaticResource ModernComboBoxStyle}"
                              Height="40"
                              SelectionChanged="CmbFilterStatus_SelectionChanged">

                            <ComboBoxItem Content="All Status" IsSelected="True"/>
                            <ComboBoxItem Content="Active"/>
                            <ComboBoxItem Content="Completed"/>
                            <ComboBoxItem Content="Cancelled"/>
                            <ComboBoxItem Content="On Hold"/>

                        </ComboBox>
                        
                    </StackPanel>

                    <StackPanel Grid.Column="5"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom">

                        <Button x:Name="btnExportPDF"
                                Content="Export PDF"
                                Style="{StaticResource ExportPdfButtonStyle}"
                                Width="120"
                                Height="42"
                                Margin="0,0,10,0"
                                Click="BtnExportPDF_Click"/>

                        <Button x:Name="btnExportExcel"
                                Content="Export Excel"
                                Style="{StaticResource ExportExcelButtonStyle}"
                                Width="120"
                                Height="42"
                                Click="BtnExportExcel_Click"/>

                    </StackPanel>

                </Grid>

            </Border>



            <!-- PAYMENT PLAN LIST -->

            <Border Grid.Row="3"
                    Style="{StaticResource CardStyle}">

                <Grid Margin="24">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>


                    <TextBlock Text="Payment Plans"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,0,0,16"/>


                    <DataGrid x:Name="dgPaymentPlans"
                              Grid.Row="1"
                              Style="{StaticResource ModernDataGridStyle}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              SelectionChanged="DgPaymentPlans_SelectionChanged">

                        <DataGrid.Columns>

                            <DataGridTextColumn Header="Plan ID" Binding="{Binding PlanId}" Width="70"/>
                            <DataGridTextColumn Header="Buyer" Binding="{Binding BuyerName}" Width="120"/>
                            <DataGridTextColumn Header="Plot" Binding="{Binding PlotNo}" Width="100"/>
                            <DataGridTextColumn Header="Plan Type" Binding="{Binding PlanType}" Width="90"/>
                            <DataGridTextColumn Header="Total Amount" Binding="{Binding TotalAmount, StringFormat='PKR {0:N2}'}" Width="150"/>
                            <DataGridTextColumn Header="Down Payment" Binding="{Binding DownPayment, StringFormat='PKR {0:N2}'}" Width="150"/>
                            <DataGridTextColumn Header="Installments" Binding="{Binding InstallmentCount}" Width="87"/>
                            <DataGridTextColumn Header="Installment Amount" Binding="{Binding InstallmentAmount, StringFormat='PKR {0:N2}'}" Width="150"/>
                            <DataGridTextColumn Header="Start Date" Binding="{Binding StartDate, StringFormat='{}{0:dd/MM/yyyy}'}" Width="100"/>

                        </DataGrid.Columns>

                    </DataGrid>

                </Grid>

            </Border>

        </Grid>

    </ScrollViewer>

</Page>